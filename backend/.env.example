# ============================================
# WorkYaar Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in real values.
# Lines starting with # are comments.

# ── Server ──────────────────────────────────
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# ── JWT Authentication ──────────────────────
# Used to sign & verify login tokens (change for production!)
JWT_SECRET=replace-with-a-long-random-secret

# ── MySQL Database ──────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=workyaar

# ── Google OAuth 2.0 ────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# IMPORTANT: Add http://localhost:5173 to "Authorized JavaScript origins"
#            Add http://localhost:5173 to "Authorized redirect URIs"
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── AI / Gemini API ─────────────────────────
# Optional. If blank, the local skill-matching fallback is used.
AI_API_KEY=

# ── Razorpay Payment Gateway ────────────────
# Optional. If blank, mock payment mode is used (auto-upgrades to Pro).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── SMTP Email (for OTP codes) ──────────────
# Optional. If blank, OTP codes are printed to the terminal console.
# For Gmail: use an "App Password" (not your real password).
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# ── Pricing (informational) ────────────────
PRO_MONTHLY_PRICE_INR=499
PRO_YEARLY_PRICE_INR=3999